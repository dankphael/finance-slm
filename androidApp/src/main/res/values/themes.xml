<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base app theme. Compose drives the actual colours; this only controls the
         window background and transparent system bars before Compose draws. -->
    <style name="Theme.FinanceSLM" parent="android:Theme.Material.Light.NoActionBar">
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowBackground">@color/window_background</item>
    </style>

    <!-- Branded launch theme (Android 12 SplashScreen API, with compat back to API 26). -->
    <style name="Theme.FinanceSLM.Starting" parent="Theme.SplashScreen">
        <item name="windowSplashScreenBackground">@color/ic_launcher_background</item>
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_launcher_foreground</item>
        <item name="postSplashScreenTheme">@style/Theme.FinanceSLM</item>
    </style>
</resources>
