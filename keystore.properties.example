# Copy this file to keystore.properties (which is git-ignored) and fill in your
# release signing details. Generate a keystore with:
#
#   keytool -genkeypair -v -keystore release.jks -alias finance-slm \
#       -keyalg RSA -keysize 2048 -validity 10000
#
storeFile=release.jks
storePassword=changeme
keyAlias=finance-slm
keyPassword=changeme
